#!/usr/bin/env ruby
# frozen_string_literal: true

# =============================================================================
# mr-review
#
# Automated GitLab Merge Request review via Claude Code.
# Fetches the MR diff, runs Claude Code in review mode, presents each comment
# for interactive validation, then submits a single batch review (draft notes)
# and approves or requests changes accordingly.
#
# Usage:
#   mr-review <MR_URL>
#   mr-review <PROJECT_PATH> <MR_IID>
#   mr-review -d ~/.mr-review/mr-review.db <MR_URL>
#
# Configuration (priority: defaults < config.yml < env vars < CLI flags):
#   ~/.mr-review/config.yml   Central config file
#   GITLAB_API_TOKEN          Personal Access Token with api scope
#   DATABASE_URL              SQLite database path (default: ~/.mr-review/mr-review.db)
#   CLAUDE_BIN                Path to claude binary (default: "claude")
#   CLAUDE_TIMEOUT            Review timeout in seconds (default: 360)
# =============================================================================

require "bundler/inline"

gemfile(true) do
  source "https://rubygems.org"
  gem "gitlab",     "~> 5.0"
  gem "tty-prompt", "~> 0.23"
  gem "tty-editor", "~> 0.7"
  gem "pastel",     "~> 0.8"
  gem "sequel",     "~> 5.0"
  gem "sqlite3",    "~> 2.0"
end

require "cgi"
require "json"
require "net/http"
require "net/https"
require "open3"
require "optparse"
require "shellwords"
require "fileutils"
require "tempfile"
require "timeout"
require "uri"
require "yaml"

# ── Exceptions ────────────────────────────────────────────────────────────────

class MrReviewError < StandardError; end

class ClaudeError < MrReviewError; end
class ClaudeTimeoutError < ClaudeError; end
class ClaudeParseError < ClaudeError; end

# ── Configuration ─────────────────────────────────────────────────────────────

REVIEW_MARKER_TAG    = "<!-- mr-reviewer-sha:"
CONTEXT_LINES        = 4

# ── Config module ─────────────────────────────────────────────────────────────

module Config
  CONFIG_DIR  = File.expand_path("~/.mr-review")
  CONFIG_PATH = File.join(CONFIG_DIR, "config.yml")

  DEFAULT_DB_PATH = File.join(CONFIG_DIR, "mr-review.db")

  DEFAULTS = {
    "database_url"     => "sqlite://#{DEFAULT_DB_PATH}",
    "gitlab_api_token" => nil,
    "claude_bin"       => "claude",
    "claude_timeout"   => 360
  }.freeze

  ENV_MAPPING = {
    "DATABASE_URL"     => "database_url",
    "GITLAB_API_TOKEN" => "gitlab_api_token",
    "CLAUDE_BIN"       => "claude_bin",
    "CLAUDE_TIMEOUT"   => "claude_timeout"
  }.freeze

  def self.load(cli_overrides = {})
    config = DEFAULTS.dup

    # Layer 2: config.yml
    if File.exist?(CONFIG_PATH)
      yaml = YAML.safe_load(File.read(CONFIG_PATH)) || {}
      yaml.each { |k, v| config[k] = v unless v.nil? }
    end

    # Layer 3: environment variables
    ENV_MAPPING.each do |env_key, config_key|
      config[config_key] = ENV[env_key] if ENV.key?(env_key)
    end

    # Layer 4: CLI flags (highest priority)
    cli_overrides.each { |k, v| config[k] = v unless v.nil? }

    # Coerce types
    config["claude_timeout"] = config["claude_timeout"].to_i

    config
  end
end

# ── Argument parsing ──────────────────────────────────────────────────────────

def parse_args(argv)
  cli_overrides = {}

  parser = OptionParser.new do |opts|
    opts.banner = "Usage:\n  mr-review [options] <MR_URL>\n  mr-review [options] <PROJECT_PATH> <MR_IID>"

    opts.on("-d", "--database-url URL", "SQLite database URL (default: sqlite://~/.mr-review/mr-review.db)") do |v|
      cli_overrides["database_url"] = v
    end

    opts.on("-t", "--token TOKEN", "GitLab API token") do |v|
      cli_overrides["gitlab_api_token"] = v
    end

    opts.on("--claude-bin PATH", "Path to claude binary") do |v|
      cli_overrides["claude_bin"] = v
    end

    opts.on("--claude-timeout SECONDS", Integer, "Review timeout in seconds") do |v|
      cli_overrides["claude_timeout"] = v
    end

    opts.on("-R", "--republish", "Republish comments from the last submitted review") do
      cli_overrides["republish"] = true
    end

    opts.on("-H", "--headless", "Skip interactive validation and submit all comments directly") do
      cli_overrides["headless"] = true
    end

    opts.on("-h", "--help", "Show this help") do
      puts opts
      exit 0
    end
  end

  positional = parser.parse(argv)

  config = Config.load(cli_overrides)

  mr_args = case positional.size
  when 1
    uri = URI.parse(positional.first)
    raise MrReviewError, "Expected an http(s) URL" unless %w[http https].include?(uri.scheme)

    base_url, _, mr_segment = uri.path.partition("/-/merge_requests/")
    raise MrReviewError, "URL does not look like a GitLab MR URL" if mr_segment.empty?

    {
      base_url:     "#{uri.scheme}://#{uri.host}",
      project_path: base_url.delete_prefix("/"),
      mr_iid:       mr_segment.split("/").first.to_i
    }
  when 2
    { base_url: nil, project_path: positional[0], mr_iid: positional[1].to_i }
  else
    raise MrReviewError, parser.to_s
  end

  mr_args.merge(config: config)
end

# ── GitLab helpers ────────────────────────────────────────────────────────────

def build_client(base_url, token)
  raise MrReviewError, "Missing GitLab API token (set GITLAB_API_TOKEN, use -t, or add to ~/.mr-review/config.yml)" unless token
  opts = { private_token: token }
  opts[:endpoint] = "#{base_url}/api/v4" if base_url
  Gitlab.client(**opts)
end

# ── Database module (Sequel + SQLite) ─────────────────────────────────────────

module Database
  @db = nil

  def self.connect(url)
    return unless url
    # Ensure the directory exists for the SQLite file
    if url.start_with?("sqlite://")
      db_path = url.sub("sqlite://", "")
      FileUtils.mkdir_p(File.dirname(db_path))
    end
    @db = Sequel.connect(url, max_connections: 1)
    @db.run("PRAGMA journal_mode=WAL")
    @db.run("PRAGMA foreign_keys=ON")
    migrate!
    true
  rescue Sequel::DatabaseConnectionError, Sequel::DatabaseError => e
    warn "  ⚠ Database connection failed: #{e.message}"
    @db = nil
    false
  end

  def self.connected?
    !@db.nil?
  end

  def self.disconnect
    @db&.disconnect
    @db = nil
  end

  # ── Schema migration ──

  def self.migrate!
    @db.run <<~SQL
      CREATE TABLE IF NOT EXISTS reviews (
        id                  INTEGER PRIMARY KEY AUTOINCREMENT,
        project_path        TEXT    NOT NULL,
        mr_iid              INTEGER NOT NULL,
        mr_title            TEXT,
        source_branch       TEXT,
        target_branch       TEXT,
        head_sha            TEXT    NOT NULL,
        previous_sha        TEXT,
        verdict             TEXT,
        claude_verdict      TEXT,
        status              TEXT    NOT NULL DEFAULT 'pending',
        summary             TEXT,
        pipeline_summary    TEXT,
        comments_total      INTEGER DEFAULT 0,
        comments_kept       INTEGER DEFAULT 0,
        claude_duration_sec REAL,
        started_at          TEXT    NOT NULL DEFAULT (datetime('now')),
        finished_at         TEXT,
        CHECK (status IN ('pending','reviewing','validated','submitted','cancelled','error'))
      );
    SQL
    @db.run <<~SQL
      CREATE INDEX IF NOT EXISTS idx_reviews_lookup
        ON reviews (project_path, mr_iid, head_sha, status);
    SQL

    @db.run <<~SQL
      CREATE TABLE IF NOT EXISTS review_comments (
        id            INTEGER PRIMARY KEY AUTOINCREMENT,
        review_id     INTEGER NOT NULL REFERENCES reviews(id) ON DELETE CASCADE,
        file          TEXT    NOT NULL,
        line          INTEGER NOT NULL,
        severity      TEXT,
        category      TEXT,
        body          TEXT    NOT NULL,
        original_body TEXT,
        status        TEXT    NOT NULL DEFAULT 'accepted',
        position      INTEGER NOT NULL,
        created_at    TEXT    NOT NULL DEFAULT (datetime('now')),
        CHECK (status IN ('accepted','edited','skipped'))
      );
    SQL
    @db.run <<~SQL
      CREATE INDEX IF NOT EXISTS idx_review_comments_review ON review_comments (review_id);
    SQL

    @db.run <<~SQL
      CREATE TABLE IF NOT EXISTS review_errors (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        review_id   INTEGER REFERENCES reviews(id) ON DELETE SET NULL,
        error_class TEXT NOT NULL,
        message     TEXT NOT NULL,
        detail      TEXT,
        phase       TEXT,
        created_at  TEXT NOT NULL DEFAULT (datetime('now'))
      );
    SQL
    @db.run <<~SQL
      CREATE INDEX IF NOT EXISTS idx_review_errors_review ON review_errors (review_id);
    SQL
  end

  # ── Reviews CRUD ──

  def self.insert_review(project_path:, mr_iid:, head_sha:, mr_title: nil,
                         source_branch: nil, target_branch: nil, previous_sha: nil)
    return nil unless connected?
    @db[:reviews].insert(
      project_path:  project_path,
      mr_iid:        mr_iid,
      head_sha:      head_sha,
      mr_title:      mr_title,
      source_branch: source_branch,
      target_branch: target_branch,
      previous_sha:  previous_sha,
      status:        "pending"
    )
  end

  def self.update_review(review_id, **fields)
    return unless connected? && review_id
    @db[:reviews].where(id: review_id).update(**fields)
  end

  def self.find_validated_review(project_path, mr_iid, head_sha)
    return nil unless connected?
    @db[:reviews].where(
      project_path: project_path,
      mr_iid:       mr_iid,
      head_sha:     head_sha,
      status:       "validated"
    ).order(Sequel.desc(:id)).first
  end

  def self.find_republishable_review(project_path, mr_iid)
    return nil unless connected?
    @db[:reviews].where(
      project_path: project_path,
      mr_iid:       mr_iid,
      status:       %w[submitted validated error]
    ).exclude(comments_kept: [nil, 0]).order(Sequel.desc(:id)).first
  end

  def self.last_reviewed_sha(project_path, mr_iid)
    return nil unless connected?
    row = @db[:reviews].where(
      project_path: project_path,
      mr_iid:       mr_iid,
      status:       "submitted"
    ).order(Sequel.desc(:id)).select(:head_sha).first
    row&.[](:head_sha)
  end

  # ── Comments CRUD ──

  def self.insert_comment(review_id:, file:, line:, severity:, category:,
                          body:, original_body: nil, status:, position:)
    return unless connected? && review_id
    @db[:review_comments].insert(
      review_id:     review_id,
      file:          file,
      line:          line,
      severity:      severity,
      category:      category,
      body:          body,
      original_body: original_body,
      status:        status,
      position:      position
    )
  end

  def self.comments_for_review(review_id)
    return [] unless connected? && review_id
    @db[:review_comments].where(review_id: review_id).order(:position).all
  end

  # ── Errors CRUD ──

  def self.insert_error(review_id: nil, error_class:, message:, detail: nil, phase: nil)
    return unless connected?
    @db[:review_errors].insert(
      review_id:   review_id,
      error_class: error_class,
      message:     message,
      detail:      detail,
      phase:       phase
    )
  rescue StandardError => e
    warn "  ⚠ Failed to log error to DB: #{e.message}"
  end
end

# URL-encode a project path so slashes become %2F for the REST API path segment.
def encode_project(path_or_id)
  CGI.escape(path_or_id.to_s)
end

# ── Idempotence check ─────────────────────────────────────────────────────────

# Returns the SHA that was reviewed in the most recent bot note, or nil.
def last_reviewed_sha(client, project_id, mr_iid)
  page = 1
  loop do
    notes = client.merge_request_notes(project_id, mr_iid,
                                       sort: "desc", page: page, per_page: 100)
    return nil if notes.empty?

    notes.each do |note|
      if (m = note.body.to_s.match(/#{Regexp.escape(REVIEW_MARKER_TAG)}([0-9a-f]{40})/))
        return m[1]
      end
    end

    break if notes.size < 100
    page += 1
  end
  nil
end

# ── Repository management (clone into /tmp) ───────────────────────────────────

class RepoManager
  attr_reader :repo_path

  def initialize(base_url:, project_path:, source_branch:, mr_iid:, token:)
    uri = URI.parse(base_url)
    host_port = uri.port && ![80, 443].include?(uri.port) ? "#{uri.host}:#{uri.port}" : uri.host
    @clone_url     = "#{uri.scheme}://oauth2:#{token}@#{host_port}/#{project_path}.git"
    @source_branch = source_branch
    @repo_path     = File.join("/tmp", "mr-review_#{mr_iid}_#{Process.pid}")
  end

  def setup!
    FileUtils.rm_rf(@repo_path) if Dir.exist?(@repo_path)
    git! "clone --branch #{Shellwords.escape(@source_branch)} " \
         "#{Shellwords.escape(@clone_url)} #{Shellwords.escape(@repo_path)}"
  end

  def teardown!
    FileUtils.rm_rf(@repo_path) if @repo_path && Dir.exist?(@repo_path)
  end

  private

  def git!(cmd)
    out, status = Open3.capture2e("git #{cmd}")
    # Mask the token in error messages
    raise MrReviewError, "git #{cmd.gsub(/oauth2:[^@]+@/, 'oauth2:****@')}\n  failed: #{out.strip}" unless status.success?
  end
end

# ── Pipeline fetcher ──────────────────────────────────────────────────────────

class PipelineFetcher
  attr_reader :pipeline, :jobs, :failed_jobs

  def initialize(client:, project:, mr_iid:, head_sha:, repo_path:)
    @client    = client
    @project   = project
    @mr_iid    = mr_iid
    @head_sha  = head_sha
    @repo_path = repo_path
    @pipeline  = nil
    @jobs      = []
    @failed_jobs = []
  end

  # Returns true if a pipeline was found and processed, false otherwise.
  def fetch!
    pipelines = @client.merge_request_pipelines(@project, @mr_iid)
    @pipeline = pipelines.find { |p| p.sha == @head_sha }
    return false unless @pipeline

    @jobs = @client.pipeline_jobs(@project, @pipeline.id, per_page: 100)
    @failed_jobs = @jobs.select { |j| j.status == "failed" }

    if @failed_jobs.any?
      log_dir = File.join(@repo_path, ".pipeline_logs")
      FileUtils.mkdir_p(log_dir)

      @failed_jobs.each do |job|
        trace = @client.job_trace(@project, job.id)
        log_path = File.join(log_dir, "job_#{job.id}_#{sanitize(job.name)}.log")
        File.write(log_path, trace)
      rescue Gitlab::Error::ResponseError => e
        warn "  ⚠ Could not fetch log for job #{job.name} (##{job.id}): #{e.message}"
      end
    end

    true
  rescue Gitlab::Error::ResponseError => e
    warn "  ⚠ Pipeline fetch failed: #{e.message}"
    false
  end

  # Returns a string to inject into the Claude prompt, or empty string if no pipeline.
  def prompt_section
    return "" unless @pipeline

    lines = []
    lines << "## Pipeline CI (SHA #{@head_sha[0, 8]})"
    lines << ""
    lines << "Pipeline ##{@pipeline.id} — status: **#{@pipeline.status}**"
    lines << ""
    lines << "| Job | Stage | Status |"
    lines << "|-----|-------|--------|"
    @jobs.each do |j|
      lines << "| #{j.name} | #{j.stage} | #{j.status} |"
    end
    lines << ""

    if @failed_jobs.any?
      lines << "### Failed job logs"
      lines << ""
      lines << "The following jobs have failed. Their logs are saved in `.pipeline_logs/`."
      lines << "Use **sub-agents** (Agent tool) to read each log file — do NOT read them directly"
      lines << "to avoid overflowing your context window."
      lines << ""
      @failed_jobs.each do |job|
        log_path = ".pipeline_logs/job_#{job.id}_#{sanitize(job.name)}.log"
        lines << "- **#{job.name}** (stage: #{job.stage}): `#{log_path}`"
      end
      lines << ""
    end

    lines.join("\n")
  end

  # Returns a step instruction for the prompt, or empty string if no pipeline.
  def prompt_step
    return "" unless @pipeline
    "\n  6. Analyse the CI pipeline data provided below. " \
    "If there are failed jobs, use **sub-agents** to read the log files in `.pipeline_logs/` " \
    "and correlate failures with the MR diff changes. Include your analysis in `pipeline_summary`."
  end

  private

  def sanitize(name)
    name.gsub(/[^a-zA-Z0-9_-]/, "_")[0, 60]
  end
end

# ── Claude Code runner ────────────────────────────────────────────────────────

REVIEW_PROMPT = <<~PROMPT
  You are performing a thorough code review of a GitLab Merge Request.

  The repository is already checked out on the MR source branch (%<review_branch>s).
  The merge target branch is: `origin/%<target>s`.

  ## Steps

  1. Run `git diff origin/%<target>s...HEAD --stat` to list changed files.
  2. Run `git diff origin/%<target>s...HEAD` to read the full diff.
  3. For each changed file, read its full content when context beyond the diff is needed.
  4. Read `CLAUDE.md` (if it exists) and any referenced skill or convention files.
  5. Check the MR commit messages (`git log origin/%<target>s..HEAD --oneline`) for context
     and for whether previous review comments (if any) have been addressed.%<pipeline_step>s

  ## Review criteria (in priority order)

  - **Bugs** – logic errors, wrong conditions, unhandled edge cases, nil-safety
  - **Security** – SQL injection, mass assignment, auth bypass, insecure storage, XSS, SSRF
  - **Business logic** – incorrect domain behaviour, race conditions, state machine issues
  - **Performance** – N+1 queries, missing DB indexes, unbounded queries, memory leaks
  - **Ruby idiom & style** – readability, idiomatic patterns, unnecessary complexity
  - **Project conventions** – anything mandated by CLAUDE.md or referenced skill files
  - **Test coverage** – missing or inadequate tests for the changes

  %<pipeline_section>s## Output format

  Respond with **only** a valid JSON object. No markdown fences, no preamble, no explanation.

  ```
  {
    "summary": "<markdown: overall assessment, 3-10 sentences>",
    "verdict": "approve" | "request_changes",
    "pipeline_summary": "<markdown: pipeline analysis — only if pipeline data is provided>",
    "comments": [
      {
        "file": "<relative file path from repo root>",
        "line": <integer — line number in the NEW version of the file>,
        "severity": "error" | "warning" | "info" | "nitpick",
        "category": "bug" | "security" | "logic" | "performance" | "style" | "test" | "other",
        "body": "<markdown comment>"
      }
    ]
  }
  ```

  ## Language

  - **All `body` fields, the `summary`, and the `pipeline_summary` must be written in French.**
  - The JSON keys and enum values (`verdict`, `severity`, `category`, etc.) stay in English.

  ## Constraints

  - `verdict` must be `"approve"` only when there are **zero** `"error"` or `"warning"` comments.
  - Only comment on lines that are part of the diff (added lines or immediate context).
  - Line numbers must correspond to the **new** version of the file after the MR changes.
  - Omit trivial nitpicks unless they violate a rule in CLAUDE.md.
  - The `comments` array may be empty only when `verdict` is `"approve"`.
  - Produce `pipeline_summary` **only** when pipeline CI data is provided above. Omit the key entirely otherwise.
PROMPT

REVIEW_JSON_SCHEMA = {
  type: "object",
  required: %w[summary verdict comments],
  additionalProperties: false,
  properties: {
    summary: { type: "string", description: "Overall assessment in French, 3-10 sentences, markdown" },
    verdict: { type: "string", enum: %w[approve request_changes] },
    pipeline_summary: { type: "string", description: "Pipeline analysis in French, markdown. Only present when pipeline data is provided." },
    comments: {
      type: "array",
      items: {
        type: "object",
        required: %w[file line severity category body],
        additionalProperties: false,
        properties: {
          file:     { type: "string", description: "Relative file path from repo root" },
          line:     { type: "integer", description: "Line number in the NEW version of the file" },
          severity: { type: "string", enum: %w[error warning info nitpick] },
          category: { type: "string", enum: %w[bug security logic performance style test other] },
          body:     { type: "string", description: "Markdown comment in French" }
        }
      }
    }
  }
}.freeze

def run_claude_review(target_branch, review_branch, claude_bin:, claude_timeout:, repo_path:,
                      pipeline_section: "", pipeline_step: "")
  prompt = format(REVIEW_PROMPT, target: target_branch, review_branch: review_branch,
                                 pipeline_section: pipeline_section, pipeline_step: pipeline_step)

  raw_output = nil
  t0 = Process.clock_gettime(Process::CLOCK_MONOTONIC)

  schema_json = Shellwords.escape(JSON.generate(REVIEW_JSON_SCHEMA))

  Timeout.timeout(claude_timeout) do
    # Write output to a temp file to avoid pipe buffer truncation on large reviews.
    Tempfile.create(["claude_review", ".txt"]) do |f|
      f.close
      system("#{claude_bin} -p #{Shellwords.escape(prompt)} --max-turns 30 --output-format json --json-schema #{schema_json} > #{Shellwords.escape(f.path)} 2>&1", chdir: repo_path)
      unless $CHILD_STATUS.success?
        raise ClaudeError, "#{claude_bin} -p exited with status #{$CHILD_STATUS.exitstatus}\n#{File.read(f.path)[0, 500]}"
      end
      raw_output = File.read(f.path)
    end
  end

  duration = Process.clock_gettime(Process::CLOCK_MONOTONIC) - t0

  # With --output-format json + --json-schema, Claude wraps the result in a JSON envelope.
  # The structured output lives in "structured_output", not "result".
  envelope = JSON.parse(raw_output)

  review = if envelope.is_a?(Hash) && envelope["structured_output"].is_a?(Hash)
    envelope["structured_output"]
  elsif envelope.is_a?(Hash) && envelope["result"].is_a?(String) && !envelope["result"].empty?
    JSON.parse(envelope["result"])
  else
    raise ClaudeParseError, "Unexpected envelope structure: #{envelope.keys.inspect}"
  end

  { "review" => review, "duration" => duration.round(1) }
rescue Timeout::Error
  raise ClaudeTimeoutError, "Claude Code timed out after #{claude_timeout}s. Try increasing CLAUDE_TIMEOUT."
rescue JSON::ParserError => e
  raise ClaudeParseError, "Claude returned invalid JSON: #{e.message}\n\nRaw output:\n#{raw_output&.[](0, 1000)}"
end

# ── Interactive comment validator ─────────────────────────────────────────────

class CommentValidator
  def initialize(comments, pastel:, prompt:, repo_path: ".")
    @comments  = comments
    @pastel    = pastel
    @prompt    = prompt
    @repo_path = repo_path
  end

  # Returns ALL comments (accepted, edited, and skipped) with tracking metadata:
  #   _review_status  : "accepted" | "edited" | "skipped"
  #   _original_body  : original Claude body (only when edited)
  def run
    return [] if @comments.empty?

    puts @pastel.bold.cyan("\n── Reviewing #{@comments.size} comment(s) ───────────────────────")

    @comments.each_with_index.map do |comment, idx|
      render_comment(comment, idx + 1)

      action = @prompt.select(
        "Action?",
        [ "Accept", "Edit", "Skip" ],
        cycle: true,
        per_page: 3
      )

      case action
      when "Accept"
        comment.merge("_review_status" => "accepted")
      when "Edit"
        edited_body = edit_in_editor(comment["body"])
        if edited_body&.strip&.length&.positive?
          comment.merge(
            "_review_status" => "edited",
            "_original_body" => comment["body"],
            "body"           => edited_body
          )
        else
          comment.merge("_review_status" => "skipped")
        end
      when "Skip"
        comment.merge("_review_status" => "skipped")
      end
    end
  end

  private

  def render_comment(comment, index)
    system("clear") || system("cls")
    c = @pastel

    puts c.bold.cyan("── Comment #{index}/#{@comments.size} " + "─" * 40)
    puts "  #{c.bold(comment["file"])}:#{c.bold(comment["line"].to_s)}"
    puts "  #{c.yellow("[#{comment["severity"].upcase}]")} #{c.dim(comment["category"])}"
    puts c.dim("─" * 60)

    puts c.bold("\nFile context:")
    puts file_context(comment["file"], comment["line"].to_i)

    puts c.bold("\nComment:")
    puts comment["body"]
    puts
  end

  def file_context(path, target_line)
    full_path = File.join(@repo_path, path)
    return @pastel.dim("  (file not found on disk)") unless File.exist?(full_path)

    lines = File.readlines(full_path)
    from  = [target_line - CONTEXT_LINES - 1, 0].max
    to    = [target_line + CONTEXT_LINES - 1, lines.size - 1].min

    lines[from..to].each_with_index.map do |text, i|
      lineno  = from + i + 1
      current = lineno == target_line
      prefix  = current ? @pastel.red.bold("▶ ") : "  "
      num     = @pastel.dim(lineno.to_s.rjust(5))
      body    = current ? @pastel.bold(text.chomp) : text.chomp
      "#{prefix}#{num}  #{body}"
    end.join("\n")
  end

  def edit_in_editor(initial_text)
    Tempfile.create(["mr_comment", ".md"]) do |f|
      f.write(initial_text)
      f.flush
      TTY::Editor.open(f.path)
      File.read(f.path)
    end
  end
end

# ── Draft state persistence ───────────────────────────────────────────────────
#
# Before any GitLab API call, the validated review is saved to a local JSON
# file.  This allows resuming after a network or server error without losing
# the edits made during interactive validation.
# The file is deleted automatically on successful submission.

module DraftState
  def self.path(mr_iid)
    ".mr-review_draft_#{mr_iid}.json"
  end

  def self.save(mr_iid, comments:, summary:, verdict:, sha:, pipeline_summary: nil)
    data = { comments: comments, summary: summary, verdict: verdict, sha: sha }
    data[:pipeline_summary] = pipeline_summary if pipeline_summary
    File.write(path(mr_iid), JSON.pretty_generate(data))
  end

  def self.load(mr_iid)
    file = path(mr_iid)
    return nil unless File.exist?(file)
    JSON.parse(File.read(file))
  end

  def self.delete(mr_iid)
    File.delete(path(mr_iid)) if File.exist?(path(mr_iid))
  end
end

# ── GitLab draft-notes submitter ──────────────────────────────────────────────
#
# The `gitlab` gem does not expose draft notes endpoints and does not support
# sending nested JSON bodies for arbitrary paths, so we use Net::HTTP directly.

class ReviewSubmitter
  # Raised when the GitLab API returns an unexpected HTTP status.
  class ApiError < StandardError
    attr_reader :status, :body

    def initialize(status, body)
      @status = status
      @body   = body
      super("HTTP #{status}")
    end

    def detail
      parsed = JSON.parse(@body) rescue nil
      if parsed.is_a?(Hash) && parsed["message"]
        parsed["message"].is_a?(Array) ? parsed["message"].join(", ") : parsed["message"].to_s
      elsif parsed.is_a?(Hash) && parsed["error"]
        parsed["error"].to_s
      else
        @body[0, 200]
      end
    end
  end

  def initialize(base_url:, token:, project_id:, mr_iid:, diff_refs:)
    @token       = token
    @mr_iid      = mr_iid
    @diff_refs   = diff_refs
    @project_id  = project_id.to_s
    @enc_project = CGI.escape(@project_id)
    @api_root    = "#{base_url}/api/v4"
  end

  # Creates draft notes (inline + summary), publishes them in one batch,
  # then approves the MR if verdict is "approve".
  # Raises ApiError on any unrecoverable GitLab error.
  def submit(comments:, summary:, verdict:, sha:, gitlab_client:, is_re_review: false,
             pipeline_summary: nil)
    delete_stale_drafts!

    inline_errors = []
    comments.each do |comment|
      create_draft_note(comment["body"], position: build_position(comment))
    rescue ApiError => e
      inline_errors << "#{comment["file"]}:#{comment["line"]} — #{e.detail}"
    end

    unless inline_errors.empty?
      warn "\n  ⚠ #{inline_errors.size} inline note(s) could not be created:"
      inline_errors.each { |err| warn "    • #{err}" }
    end

    marker = "#{REVIEW_MARKER_TAG}#{sha} -->"
    if is_re_review
      create_draft_note(marker)
    else
      create_draft_note(":mag: **Code Review**\n\n#{summary}\n\n#{marker}")
    end

    if pipeline_summary && !pipeline_summary.strip.empty?
      create_draft_note(":construction: **Pipeline**\n\n#{pipeline_summary}")
    end

    publish_all_drafts!

    gitlab_client.approve_merge_request(@project_id, @mr_iid) if verdict == "approve"
  end

  private

  def create_draft_note(body, position: nil)
    payload = { note: body }
    payload[:position] = position if position
    http_post(draft_notes_uri, payload)
  end

  def delete_stale_drafts!
    drafts = http_get(draft_notes_uri)
    return unless drafts.is_a?(Array) && !drafts.empty?

    warn "  ⚠ Deleting #{drafts.size} stale draft note(s) from previous attempts…"
    drafts.each do |draft|
      http_delete(URI("#{draft_notes_uri}/#{draft["id"]}"))
    rescue ApiError
      # best effort
    end
  end

  def publish_all_drafts!
    drafts = http_get(draft_notes_uri)
    return if drafts.empty?

    publish_errors = []
    drafts.each do |draft|
      uri = URI("#{draft_notes_uri}/#{draft["id"]}/publish")
      http_put(uri)
    rescue ApiError => e
      publish_errors << "draft##{draft["id"]} — #{e.status}: #{e.detail}"
    end

    unless publish_errors.empty?
      warn "\n  ⚠ #{publish_errors.size} draft(s) failed to publish:"
      publish_errors.each { |err| warn "    • #{err}" }
    end
  end

  def build_position(comment)
    {
      position_type: "text",
      base_sha:      @diff_refs.base_sha,
      start_sha:     @diff_refs.start_sha,
      head_sha:      @diff_refs.head_sha,
      old_path:      comment["file"],
      new_path:      comment["file"],
      new_line:      comment["line"]
    }
  end

  def draft_notes_uri
    URI("#{@api_root}/projects/#{@enc_project}/merge_requests/#{@mr_iid}/draft_notes")
  end

  def http_post(uri, payload)
    http              = Net::HTTP.new(uri.host, uri.port)
    http.use_ssl      = (uri.scheme == "https")
    http.read_timeout = 30

    req = Net::HTTP::Post.new(uri)
    req["PRIVATE-TOKEN"] = @token
    req["Content-Type"]  = "application/json"
    req.body = payload.to_json

    response = http.request(req)
    code     = response.code.to_i
    unless (200..299).cover?(code)
      warn "  [DEBUG] POST #{uri.path} → #{code}"
      warn "  [DEBUG] Request body: #{payload.to_json[0, 500]}"
      warn "  [DEBUG] Response body: #{response.body[0, 500]}"
      raise ApiError.new(code, response.body)
    end

    JSON.parse(response.body) rescue {}
  end

  def http_get(uri)
    http              = Net::HTTP.new(uri.host, uri.port)
    http.use_ssl      = (uri.scheme == "https")
    http.read_timeout = 30

    req = Net::HTTP::Get.new(uri)
    req["PRIVATE-TOKEN"] = @token

    response = http.request(req)
    code     = response.code.to_i
    raise ApiError.new(code, response.body) unless (200..299).cover?(code)

    JSON.parse(response.body) rescue []
  end

  def http_put(uri)
    http              = Net::HTTP.new(uri.host, uri.port)
    http.use_ssl      = (uri.scheme == "https")
    http.read_timeout = 30

    req = Net::HTTP::Put.new(uri)
    req["PRIVATE-TOKEN"] = @token

    response = http.request(req)
    code     = response.code.to_i
    unless (200..299).cover?(code)
      warn "  [DEBUG] PUT #{uri.path} → #{code}"
      warn "  [DEBUG] Response body: #{response.body[0, 500]}"
      raise ApiError.new(code, response.body)
    end
  end

  def http_delete(uri)
    http              = Net::HTTP.new(uri.host, uri.port)
    http.use_ssl      = (uri.scheme == "https")
    http.read_timeout = 30

    req = Net::HTTP::Delete.new(uri)
    req["PRIVATE-TOKEN"] = @token

    response = http.request(req)
    code     = response.code.to_i
    raise ApiError.new(code, response.body) unless (200..299).cover?(code)
  end
end

# ── Main ──────────────────────────────────────────────────────────────────────

def main
  pastel = Pastel.new
  tty    = TTY::Prompt.new

  current_phase = "arg_parse"
  review_id     = nil
  repo_mgr      = nil

  puts pastel.bold.blue("╔═ MR Reviewer ═══════════════════════════════════════╗")

  # 1. Parse CLI args + load config
  args    = parse_args(ARGV)
  config  = args[:config]
  token   = config["gitlab_api_token"]
  client  = build_client(args[:base_url], token)
  project = args[:project_path]
  mr_iid  = args[:mr_iid]

  claude_bin     = config["claude_bin"]
  claude_timeout = config["claude_timeout"]

  # 2. Connect to database (optional — graceful degradation)
  current_phase = "db_connect"
  if config["database_url"]
    if Database.connect(config["database_url"])
      puts pastel.dim("  ✓ Database connected")
    end
  end

  # 3. Fetch MR metadata
  current_phase = "fetch_mr"
  puts "  Fetching MR !#{mr_iid} from #{project}…"
  mr = client.merge_request(project, mr_iid)

  puts pastel.green("  #{mr.title}")
  puts "  #{mr.source_branch} → #{mr.target_branch}"
  puts "  HEAD: #{mr.sha[0, 8]}"

  # 3b. Republish mode — re-submit comments from a previous successful review
  if config["republish"]
    current_phase = "republish"
    raise MrReviewError, "Republish requires a database connection (-d or DATABASE_URL)" unless Database.connected?

    prev = Database.find_republishable_review(project, mr_iid)
    raise MrReviewError, "No review with comments found for #{project} !#{mr_iid}" unless prev

    db_comments       = Database.comments_for_review(prev[:id])
    approved_comments = db_comments.select { |c| c[:status] != "skipped" }.map do |c|
      { "file" => c[:file], "line" => c[:line], "severity" => c[:severity],
        "category" => c[:category], "body" => c[:body] }
    end
    final_summary    = prev[:summary]
    final_verdict    = prev[:verdict]
    pipeline_summary = prev[:pipeline_summary]

    puts pastel.cyan("  Republishing review ##{prev[:id]} (#{prev[:head_sha][0, 8]}, #{approved_comments.size} comment(s))")

    base_url = args[:base_url] || "https://#{URI.parse(client.endpoint).host}"
    submitter = ReviewSubmitter.new(
      base_url: base_url, token: token, project_id: project,
      mr_iid: mr_iid, diff_refs: mr.diff_refs
    )
    submitter.submit(
      comments: approved_comments, summary: final_summary,
      verdict: final_verdict, sha: mr.sha, gitlab_client: client,
      pipeline_summary: pipeline_summary
    )
    puts pastel.bold.green("\n  ✅ Review republished (#{final_verdict.gsub("_", " ")}).")
    exit 0
  end

  # 4. INSERT review (status: pending)
  review_id = Database.insert_review(
    project_path:  project,
    mr_iid:        mr_iid,
    head_sha:      mr.sha,
    mr_title:      mr.title,
    source_branch: mr.source_branch,
    target_branch: mr.target_branch
  )

  # 5. Idempotence — DB first, GitLab notes fallback
  current_phase = "idempotence"
  reviewed_sha = Database.last_reviewed_sha(project, mr_iid) ||
                 last_reviewed_sha(client, project, mr_iid)

  if reviewed_sha == mr.sha
    puts pastel.yellow("\n  Commit #{mr.sha[0, 8]} has already been reviewed. Nothing to do.")
    Database.update_review(review_id, status: "submitted", previous_sha: reviewed_sha, finished_at: Sequel.lit("datetime('now')"))
    exit 0
  end

  Database.update_review(review_id, previous_sha: reviewed_sha) if reviewed_sha
  puts pastel.cyan("  Previous review SHA: #{reviewed_sha[0, 8]}") if reviewed_sha

  # 6. Resume check — DB first, DraftState fallback
  approved_comments = nil
  all_comments      = nil
  final_summary     = nil
  final_verdict     = nil
  total_comments    = nil
  pipeline_summary  = nil

  db_draft = Database.find_validated_review(project, mr_iid, mr.sha)
  if db_draft
    puts pastel.yellow("\n  ⚠ A validated review exists in DB for commit #{mr.sha[0, 8]}.")
    if tty.yes?("Resume from DB draft? (No = start fresh)")
      db_comments       = Database.comments_for_review(db_draft[:id])
      approved_comments = db_comments.select { |c| c[:status] != "skipped" }.map do |c|
        { "file" => c[:file], "line" => c[:line], "severity" => c[:severity],
          "category" => c[:category], "body" => c[:body] }
      end
      final_summary    = db_draft[:summary]
      final_verdict    = db_draft[:verdict]
      total_comments   = db_draft[:comments_total]
      pipeline_summary = db_draft[:pipeline_summary]
      # Reuse existing review row
      review_id = db_draft[:id]
      puts pastel.green("  ✓ Loaded #{approved_comments.size} comment(s) from DB.")
    end
  end

  if !approved_comments
    file_draft = DraftState.load(mr_iid)
    if file_draft && file_draft["sha"] == mr.sha
      puts pastel.yellow("\n  ⚠ A saved draft exists for commit #{mr.sha[0, 8]} (#{DraftState.path(mr_iid)}).")
      if tty.yes?("Resume from saved draft? (No = start fresh)")
        approved_comments = file_draft["comments"]
        final_summary     = file_draft["summary"]
        final_verdict     = file_draft["verdict"]
        pipeline_summary  = file_draft["pipeline_summary"]
        total_comments    = approved_comments.size
        puts pastel.green("  ✓ Loaded #{approved_comments.size} comment(s) from draft file.")
      end
    end
  end

  unless approved_comments
    # 7. Clone repository into /tmp
    current_phase = "clone"
    clone_base_url = args[:base_url] || "https://#{URI.parse(client.endpoint).host}"
    repo_mgr = RepoManager.new(
      base_url:      clone_base_url,
      project_path:  project,
      source_branch: mr.source_branch,
      mr_iid:        mr_iid,
      token:         token
    )
    at_exit { repo_mgr&.teardown! }
    repo_mgr.setup!
    puts pastel.green("  ✓ Cloned into #{repo_mgr.repo_path}")

    # 7b. Fetch CI pipeline
    current_phase = "pipeline"
    pf = PipelineFetcher.new(
      client: client, project: project, mr_iid: mr_iid,
      head_sha: mr.sha, repo_path: repo_mgr.repo_path
    )
    if pf.fetch!
      puts pastel.green("  ✓ Pipeline ##{pf.pipeline.id} (#{pf.pipeline.status}) — #{pf.jobs.size} job(s), #{pf.failed_jobs.size} failed")
    else
      puts pastel.dim("  ℹ No pipeline found for HEAD SHA #{mr.sha[0, 8]}")
    end

    # 8. Run Claude Code review
    current_phase = "claude"
    Database.update_review(review_id, status: "reviewing")
    puts pastel.bold("\n  ⏳ Running Claude Code review (timeout: #{claude_timeout}s)…")

    result   = run_claude_review(mr.target_branch, mr.source_branch,
                                 claude_bin: claude_bin, claude_timeout: claude_timeout,
                                 repo_path: repo_mgr.repo_path,
                                 pipeline_section: pf.prompt_section,
                                 pipeline_step: pf.prompt_step)
    review   = result["review"]
    duration = result["duration"]

    Database.update_review(review_id, claude_duration_sec: duration, claude_verdict: review["verdict"])
    puts pastel.green("  ✓ #{review["comments"].size} comment(s) — initial verdict: #{review["verdict"]} (#{duration}s)")

    total_comments = review["comments"].size

    # 9. Comment validation (interactive or headless)
    current_phase = "validate"
    if config["headless"]
      all_comments = review["comments"].map { |c| c.merge("_review_status" => "accepted") }
      puts pastel.dim("  Headless mode — accepting all #{all_comments.size} comment(s)")
    else
      validator    = CommentValidator.new(review["comments"], pastel: pastel, prompt: tty, repo_path: repo_mgr.repo_path)
      all_comments = validator.run
    end

    # Insert all comments into DB
    all_comments.each_with_index do |c, idx|
      Database.insert_comment(
        review_id:     review_id,
        file:          c["file"],
        line:          c["line"],
        severity:      c["severity"],
        category:      c["category"],
        body:          c["body"],
        original_body: c["_original_body"],
        status:        c["_review_status"],
        position:      idx + 1
      )
    end

    approved_comments = all_comments.reject { |c| c["_review_status"] == "skipped" }

    has_blocking     = approved_comments.any? { |c| %w[error warning].include?(c["severity"]) }
    final_verdict    = has_blocking ? "request_changes" : review["verdict"]
    final_summary    = review["summary"]
    pipeline_summary = review["pipeline_summary"]

    # 10. UPDATE status: validated
    Database.update_review(review_id,
      status:           "validated",
      verdict:          final_verdict,
      summary:          final_summary,
      pipeline_summary: pipeline_summary,
      comments_total:   total_comments,
      comments_kept:    approved_comments.size
    )
  end

  # 11. Final review screen — summary edit + confirmation
  current_phase = "validate"
  unless config["headless"]
    loop do
      system("clear")
      puts pastel.bold.cyan("── Final Review ─────────────────────────────────────────────")
      puts final_summary
      puts

      if pipeline_summary && !pipeline_summary.strip.empty?
        puts pastel.bold.cyan("── Pipeline ─────────────────────────────────────────────────")
        puts pipeline_summary
        puts
      end

      puts "  Inline comments : #{approved_comments.size} / #{total_comments} kept"

      verdict_display = if final_verdict == "approve"
        pastel.green.bold("APPROVE ✓")
      else
        pastel.red.bold("REQUEST CHANGES ✗")
      end
      puts "  Verdict         : #{verdict_display}"
      puts

      menu_choices = ["Submit", "Edit summary"]
      menu_choices << "Edit pipeline summary" if pipeline_summary && !pipeline_summary.strip.empty?
      menu_choices << "Cancel"

      action = tty.select("Action?", menu_choices, cycle: true)

      case action
      when "Edit summary"
        edited = nil
        Tempfile.create(["mr_summary", ".md"]) do |f|
          f.write(final_summary)
          f.flush
          TTY::Editor.open(f.path)
          edited = File.read(f.path).strip
        end
        if edited && !edited.empty?
          final_summary = edited
          Database.update_review(review_id, summary: final_summary)
        end
      when "Edit pipeline summary"
        edited = nil
        Tempfile.create(["mr_pipeline", ".md"]) do |f|
          f.write(pipeline_summary)
          f.flush
          TTY::Editor.open(f.path)
          edited = File.read(f.path).strip
        end
        if edited && !edited.empty?
          pipeline_summary = edited
          Database.update_review(review_id, pipeline_summary: pipeline_summary)
        end
      when "Cancel"
        Database.update_review(review_id, status: "cancelled", finished_at: Sequel.lit("datetime('now')"))
        puts pastel.yellow("  Review cancelled. Nothing was submitted.")
        exit 0
      when "Submit"
        break
      end
    end
  end

  # 12. Persist draft as fallback before any GitLab call
  current_phase = "submit"
  unless Database.connected?
    DraftState.save(mr_iid,
      comments:         approved_comments,
      summary:          final_summary,
      verdict:          final_verdict,
      sha:              mr.sha,
      pipeline_summary: pipeline_summary
    )
    puts pastel.dim("  Draft saved to #{DraftState.path(mr_iid)}")
  end

  # 13. Submit to GitLab
  base_url = args[:base_url] || "https://#{URI.parse(client.endpoint).host}"

  submitter = ReviewSubmitter.new(
    base_url:   base_url,
    token:      token,
    project_id: project,
    mr_iid:     mr_iid,
    diff_refs:  mr.diff_refs
  )

  submitter.submit(
    comments:         approved_comments,
    summary:          final_summary,
    verdict:          final_verdict,
    sha:              mr.sha,
    gitlab_client:    client,
    is_re_review:     !!reviewed_sha,
    pipeline_summary: pipeline_summary
  )

  # 14. UPDATE status: submitted
  Database.update_review(review_id,
    status:      "submitted",
    finished_at: Sequel.lit("datetime('now')")
  )

  DraftState.delete(mr_iid)
  puts pastel.bold.green("\n  ✅ Review submitted (#{final_verdict.gsub("_", " ")}).")

rescue MrReviewError, ReviewSubmitter::ApiError => e
  Database.insert_error(
    review_id:   review_id,
    error_class: e.class.name,
    message:     e.message,
    phase:       current_phase
  )
  Database.update_review(review_id, status: "error", finished_at: Sequel.lit("datetime('now')"))

  pastel ||= Pastel.new
  warn pastel.red.bold("\n  ✖ #{e.class}: #{e.message}")
  if e.is_a?(ReviewSubmitter::ApiError)
    warn pastel.red("    #{e.detail}")
    warn pastel.yellow("  Draft saved — re-run the script to retry without losing your edits.") unless Database.connected?
  end
  exit 1

rescue Interrupt
  Database.update_review(review_id, status: "cancelled", finished_at: Sequel.lit("datetime('now')"))
  pastel ||= Pastel.new
  warn pastel.yellow("\n  Interrupted. Review cancelled.")
  exit 130

rescue StandardError => e
  Database.insert_error(
    review_id:   review_id,
    error_class: e.class.name,
    message:     e.message,
    detail:      e.backtrace&.first(10)&.join("\n"),
    phase:       current_phase
  )
  Database.update_review(review_id, status: "error", finished_at: Sequel.lit("datetime('now')"))

  pastel ||= Pastel.new
  warn pastel.red.bold("\n  ✖ Unexpected error: #{e.class}: #{e.message}")
  warn pastel.dim(e.backtrace&.first(5)&.join("\n  "))
  exit 1

ensure
  Database.disconnect
end

main
